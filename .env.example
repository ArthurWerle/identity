# Server Configuration
SERVER_PORT=8080

# Environment label shown in the admin UI header (prod|staging|local)
APP_ENV=local

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=identity
DB_PASSWORD=identity_dev_password
DB_NAME=identity_db
DB_SSLMODE=disable

# Logging Configuration
LOG_LEVEL=info

# Auth Configuration
# Session lifetime in hours (default 720 = 30 days, sliding expiration)
SESSION_DURATION_HOURS=720
# Set to true when serving over HTTPS
COOKIE_SECURE=false

# Initial admin user (created on first boot when the users table is empty)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Docker compose (stack.env) variables
POSTGRES_CONTAINER_NAME=identity-postgres
POSTGRES_USER=identity
POSTGRES_PASSWORD=change_me
POSTGRES_DB=identity_db
POSTGRES_PORT=5433
SERVICE_CONTAINER_NAME=identity
SERVICE_PORT=8083
